#!/bin/sh

set -e

cd $(git rev-parse --show-toplevel)

# `cargo clippy` runs `cargo check`, which may produce warnings.
cargo clippy -p cargo-verify -p trust2-contract -p trust2-contract-macros -p utils --all-targets --all-features -- -D warnings

# `cargo fmt` does not support `--workspace`.
cargo fmt -p cargo-verify -p trust2-contract -p trust2-contract-macros -p utils --check
rustfmt charon/charon/src/bin/charon/main.rs --edition 2024 --check
