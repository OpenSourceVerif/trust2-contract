opam-version: "2.0"
depends: [
  "dune" {>= "3.22"}
  "ocaml"
  "ocamlformat" {= "0.27.0"}
  "charon"
  "why3"
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
x-maintenance-intent: ["(latest)"]
